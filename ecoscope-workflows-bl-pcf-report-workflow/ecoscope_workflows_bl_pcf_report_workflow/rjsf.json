{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set Workflow Details"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "title": "Time Format",
          "type": "string",
          "description": "The time format",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Set Report Time Range"
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to EarthRanger"
    },
    "time_frequency": {
      "additionalProperties": false,
      "properties": {
        "time_frequency": {
          "$ref": "#/$defs/TimeFrequency",
          "title": "Time Frequency",
          "description": "The time frequency to use across all time-series charts in the workflow."
        }
      },
      "required": [
        "time_frequency"
      ],
      "type": "object",
      "title": "Select time frequency for temporal charts"
    },
    "Previous period time range": {
      "type": "object",
      "description": "Automatically calculated from the report time range above \u2014 shifted back by one equivalent period. For example, if the report covers Jan 1\u2013Feb 1, the previous period will be Dec 1\u2013Jan 1. This is used to compare current events against the same duration in the prior period.",
      "ecoscope:task_group": true,
      "properties": {
        "previous_period_range": {
          "additionalProperties": false,
          "properties": {
            "periods_back": {
              "default": 1,
              "minimum": 1,
              "title": "Periods Back",
              "type": "integer",
              "description": "How many periods back to shift (default: 1 = the immediately preceding period). Increase to compare against a more distant reference window."
            }
          },
          "required": [],
          "type": "object",
          "title": ""
        }
      },
      "title": "Previous Period Range"
    }
  },
  "$defs": {
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "TimeFrequency": {
      "enum": [
        "Year",
        "Quarter",
        "Month",
        "Week",
        "Day",
        "Hour",
        "Minute"
      ],
      "title": "TimeFrequency",
      "type": "string"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone",
        "time_format"
      ]
    },
    "ui:order": [
      "workflow_details",
      "time_range",
      "er_client_name",
      "time_frequency",
      "Previous period time range"
    ]
  },
  "additionalProperties": false
}
